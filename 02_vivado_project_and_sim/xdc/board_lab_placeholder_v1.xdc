# Lab package-pin placeholder v1 for xczu9eg-ffvb1156-2-e.
#
# Purpose:
#   - Provide concrete PACKAGE_PIN and IOSTANDARD constraints so bitstream DRC
#     no longer stops on NSTD-1 / UCIO-1 during lab builds.
#   - Keep the mapping versioned and easy to replace when the real board
#     schematic pinout is available.
#
# Hardware note:
#   This is not a verified board pinout. Do not use this file for physical
#   hardware bring-up until every LOC and the bank VCCO have been checked
#   against the actual schematic.
#
# Vivado 2017.3 XDC note:
#   This file intentionally uses only plain set_property commands. Older Vivado
#   releases do not support proc/foreach in XDC files.

# Single-ended lab default. The board VCCO must match this before hardware use.
set_property IOSTANDARD LVCMOS18 [get_ports -quiet *]

set_property PACKAGE_PIN Y5   [get_ports clk_sys]
set_property PACKAGE_PIN AA7  [get_ports clk_byte]
